+  async _buildTronTransaction ({ to, value, data, feeLimit }) {
+    const address = await this.getAddress()
+
+    if (!data) {
+      // Upstream-equivalent plain TRX transfer path.
+      return await this._tronWeb.transactionBuilder.sendTrx(to, value, address)
