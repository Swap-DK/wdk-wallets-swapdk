{
  "name": "@swapdk/wdk-wallet-btc",
  "version": "0.1.3",
  "description": "WDK wallet module for Bitcoin, extending @tetherto/wdk-wallet-btc with OP_RETURN memo support so sendTransaction can attach swap memos (e.g. THORChain). Fork of @tetherto/wdk-wallet-btc.",
  "keywords": [
    "wdk",
    "wallet",
    "bip-32",
    "bitcoin",
    "thorchain",
    "op-return",
    "swapdk"
  ],
  "author": "SwapDK",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Swap-DK/wdk-wallets-swapdk.git",
    "directory": "packages/btc"
  },
  "bugs": {
    "url": "https://github.com/Swap-DK/wdk-wallets-swapdk/issues"
  },
  "homepage": "https://swapdk.com",
  "main": "index.js",
  "type": "module",
  "types": "./types/index.d.ts",
  "files": [
    "index.js",
    "bare.js",
    "src/",
    "types/",
    "!types/tests/",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "scripts": {
    "clean": "rm -rf types",
    "build": "tsc",
    "prepack": "npm run clean && npm run build",
    "lint": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "bare": "./bare.js",
      "default": "./index.js"
    },
    "./package": {
      "default": "./package.json"
    }
  },
  "dependencies": {
    "@bitcoinerlab/coinselect": "1.3.1",
    "@bitcoinerlab/descriptors": "2.3.1",
    "@bitcoinerlab/secp256k1": "1.2.0",
    "@mempool/electrum-client": "1.1.9",
    "@tetherto/wdk-failover-provider": "1.0.0-beta.2",
    "@tetherto/wdk-wallet": "1.0.0-beta.8",
    "bare-node-runtime": "1.1.4",
    "bip32": "4.0.0",
    "bip39": "3.1.0",
    "bitcoinjs-lib": "6.1.7",
    "bitcoinjs-message": "2.2.0",
    "lru-cache": "11.2.2",
    "p-limit": "7.1.1",
    "sodium-universal": "5.0.1"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
