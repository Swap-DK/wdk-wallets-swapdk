{
  "include": ["index.js", "src", "tests"],
  "compilerOptions": {
    "target": "ES2015",
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": false,
    "strict": false,
    "isolatedModules": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "skipLibCheck": true,
    "stripInternal": true,
    "outDir": "./types"
  }
}
